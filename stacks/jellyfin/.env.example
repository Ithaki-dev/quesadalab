# Internal hostname served by Traefik and resolved by AdGuard Home.
JELLYFIN_FQDN=jellyfin.lab

# Pin upgrades to an explicitly reviewed stable release.
JELLYFIN_VERSION=10.11.11

# Persistent application state remains on the VM system disk.
JELLYFIN_CONFIG_LOCATION=/opt/quesadalab/data/jellyfin/config

# Media, cache, and transcodes use the dedicated 200 GiB disk.
JELLYFIN_MEDIA_LOCATION=/srv/jellyfin-media
JELLYFIN_CACHE_LOCATION=/srv/jellyfin-media/cache
JELLYFIN_TRANSCODE_LOCATION=/srv/jellyfin-media/transcodes

# Unprivileged process identity. Match ownership on the live host.
JELLYFIN_UID=1000
JELLYFIN_GID=1000

# Match the host groups that own /dev/dri/card0 and renderD128.
JELLYFIN_VIDEO_GID=44
JELLYFIN_RENDER_GID=991

# Intel Haswell is a pre-Broadwell platform and requires VA-API/i965.
LIBVA_DRIVER_NAME=i965

TZ=America/Costa_Rica
