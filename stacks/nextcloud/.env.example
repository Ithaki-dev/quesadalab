# Public internal hostname served by Traefik and resolved by AdGuard Home.
NEXTCLOUD_HOST=nextcloud.lab

# Replace with the actual subnet returned by: docker network inspect proxy
TRUSTED_PROXIES=172.16.0.0/12

# Non-secret database identifiers.
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud

# Initial administrator username. Choose a non-obvious value in the live .env.
NEXTCLOUD_ADMIN_USER=change-me

# Validation uses the fake files below. Live must use:
# /opt/quesadalab/security/nextcloud
NEXTCLOUD_SECRETS_DIR=./secrets.example

TZ=America/Costa_Rica
