# Public internal hostname served by Traefik and resolved by AdGuard Home.
IMMICH_FQDN=immich.lab

# Pin upgrades to an explicitly reviewed Immich release.
IMMICH_VERSION=v3.0.3

# Dedicated 200 GiB data disk mounted in docker01.
UPLOAD_LOCATION=/srv/immich-data/library

# Database and model cache remain on the VM system disk.
DB_DATA_LOCATION=/opt/quesadalab/data/immich/postgres
MODEL_CACHE_LOCATION=/opt/quesadalab/data/immich/model-cache

# Replace with the actual subnet returned by: docker network inspect proxy
TRUSTED_PROXIES=172.16.0.0/12

# Set false after creating and validating the initial administrator.
IMMICH_ALLOW_SETUP=true

# Validation uses the fake file below. Live must use:
# /opt/quesadalab/security/immich
IMMICH_SECRETS_DIR=./secrets.example

DB_USERNAME=immich
DB_DATABASE_NAME=immich

# Conservative CPU-only machine-learning settings for an 8 GiB VM.
MACHINE_LEARNING_REQUEST_THREADS=2
MACHINE_LEARNING_MODEL_INTRA_OP_THREADS=2
MACHINE_LEARNING_WORKERS=1
MACHINE_LEARNING_MODEL_TTL=300

TZ=America/Costa_Rica

